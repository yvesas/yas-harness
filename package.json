{
  "name": "yas-harness",
  "version": "0.0.0",
  "description": "Reusable agent chassis (harness) for YAS Labs products",
  "license": "Apache-2.0",
  "author": "YAS Softwares LTDA",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "tsc --build tsconfig.build.json",
    "clean": "tsc --build tsconfig.build.json --clean",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "license:check": "node scripts/check-license-headers.mjs",
    "license:fix": "node scripts/check-license-headers.mjs --fix",
    "check": "npm run lint && npm run license:check && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.4"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
