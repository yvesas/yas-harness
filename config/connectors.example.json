{
  "//": "Copy to connectors.json and fill in. Each key is a CONNECTOR ID (the connection's connectorId) — so confluence and jira each get an entry even though they share Atlassian OAuth. The client secret is NOT here — name its environment variable in clientSecretEnv and set that. A missing connectors.json is fine; the connection layer then runs without OAuth.",

  "confluence": {
    "authorizationEndpoint": "https://auth.atlassian.com/authorize",
    "tokenEndpoint": "https://auth.atlassian.com/oauth/token",
    "clientId": "your-atlassian-client-id",
    "clientSecretEnv": "ATLASSIAN_CLIENT_SECRET",
    "scopes": ["read:confluence-content.all", "write:confluence-content", "offline_access"],
    "authorizationParams": { "audience": "api.atlassian.com", "prompt": "consent" }
  },

  "jira": {
    "authorizationEndpoint": "https://auth.atlassian.com/authorize",
    "tokenEndpoint": "https://auth.atlassian.com/oauth/token",
    "clientId": "your-atlassian-client-id",
    "clientSecretEnv": "ATLASSIAN_CLIENT_SECRET",
    "scopes": ["read:jira-work", "write:jira-work", "offline_access"],
    "authorizationParams": { "audience": "api.atlassian.com", "prompt": "consent" }
  },

  "github": {
    "authorizationEndpoint": "https://github.com/login/oauth/authorize",
    "tokenEndpoint": "https://github.com/login/oauth/access_token",
    "clientId": "your-github-client-id",
    "clientSecretEnv": "GITHUB_CLIENT_SECRET",
    "scopes": ["repo", "read:org"]
  },

  "google-drive": {
    "authorizationEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
    "tokenEndpoint": "https://oauth2.googleapis.com/token",
    "clientId": "your-google-client-id",
    "clientSecretEnv": "GOOGLE_CLIENT_SECRET",
    "scopes": ["https://www.googleapis.com/auth/drive.file"],
    "authorizationParams": { "access_type": "offline", "prompt": "consent" }
  }
}
