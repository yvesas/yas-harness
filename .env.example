# Copy to .env and adjust. Never commit .env.
# Loaded with `node --env-file=.env`; no dotenv dependency.

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- Ports ------------------------------------------------------------------
# The project uses the 4000 block on the host, deliberately away from the
# default ports (5432, 3000, ...) so it can run next to other projects.
# Inside the container Postgres still listens on 5432.
POSTGRES_PORT=4000
HTTP_PORT=4001

# --- Database ---------------------------------------------------------------
# docker-compose reads POSTGRES_* to provision the container; the application
# reads DATABASE_URL. Keep the port consistent with POSTGRES_PORT above.
POSTGRES_USER=harness
POSTGRES_PASSWORD=harness
POSTGRES_DB=harness
DATABASE_URL=postgres://harness:harness@localhost:4000/harness

# --- Model providers --------------------------------------------------------
# Real keys go in .env only. The agent never reads these directly: the model
# gateway resolves them at call time.
#
# Which providers you need depends on config/models.json — a deployment that
# routes only to Anthropic needs only that key.
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# --- Credential encryption --------------------------------------------------
# Master key for envelope encryption of stored credentials (32 bytes, base64).
# Generate with: openssl rand -base64 32
# MASTER_ENCRYPTION_KEY=
